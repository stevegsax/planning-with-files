# TEST-1 PRIMING BROADENING for Squid — paste-in snippet (reversible).
#
# The agent box's only egress is this Squid forward proxy, normally allowlisted to
# api.anthropic.com ONLY. To PRIME the box once (install the toolchain + warm the
# offline uv cache), temporarily broaden the allowlist, prime, then RE-FENCE.
#
# Procedure (the Squid box is a SEPARATE instance — reach it over SSM):
#   1. aws ssm start-session --target <squid-instance-id>
#   2. Edit /etc/squid/squid.conf: paste the `acl` lines below next to the existing
#      `acl anthropic ...`, and the matching `http_access allow` lines ABOVE the final
#      `http_access deny all`. Substitute your DEPLOY REGION into the al2023 hosts.
#   3. sudo systemctl reload squid
#   4. Prime the agent box (sudo systemctl start pwfg-prime.service), tailing
#      /var/log/squid/access.log here to capture every CONNECT host actually hit.
#   5. RE-FENCE: delete the pasted lines, sudo systemctl reload squid.
#   6. Re-verify the fence (must all hold):
#        curl -x http://127.0.0.1:3128 https://pypi.org        -> 403
#        curl -x http://127.0.0.1:3128 https://example.com     -> 403
#        curl -x http://127.0.0.1:3128 https://api.anthropic.com -> NOT 403 (allowed)
#
# NOTE: boot-assert does NOT check the Squid allowlist — a forgotten-open broadening is
# the dominant operational risk. Step 5+6 are operator-gated; do not skip them.
# FIRST-REAL-BOX: tail access.log (step 4) and reconcile this list against the live
# CONNECT hosts (release CDNs / Fastly / the exact al2023 S3 host(s) for your region).

# --- acl (next to `acl anthropic dstdomain api.anthropic.com`) ---
acl uv_install   dstdomain astral.sh releases.astral.sh
acl gh           dstdomain github.com objects.githubusercontent.com release-assets.githubusercontent.com
acl pypi         dstdomain pypi.org files.pythonhosted.org
# Substitute <region> (e.g. us-east-1). BOTH forms: non-dualstack = mirrorlist host,
# dualstack = blob host. Confirm the exact bucket on the box (see runbook §3).
acl al2023       dstdomain al2023-repos-<region>-de612dc2.s3.<region>.amazonaws.com al2023-repos-<region>-de612dc2.s3.dualstack.<region>.amazonaws.com
# Only if claude is installed on the box (not riding the code bundle):
acl claude_install dstdomain claude.ai downloads.claude.ai

# --- http_access (ABOVE the final `http_access deny all`) ---
http_access allow pwfg_src CONNECT uv_install SSL_ports
http_access allow pwfg_src CONNECT gh SSL_ports
http_access allow pwfg_src CONNECT pypi SSL_ports
http_access allow pwfg_src CONNECT al2023 SSL_ports
http_access allow pwfg_src CONNECT claude_install SSL_ports
