# pwfg boundary sudo rules. Two crossings only:
#   gov -> agent : spawn the unprivileged worker (the launch seam)
#   agent -> gov : the NARROW verify bridge (safe because proof strings come only
#                  from the locked plan — TRAP 1 is closed in common.sh)
# Keep PWFG_* context across the boundary. The agent->gov direction carries ONLY
# PWFG_ENV_FILE (the path to the gov-owned env file); common.sh refuses to source
# it unless it is gov-owned and not group/other-writable, so the agent cannot point
# it at a file it wrote. PWFG_PROOF_AS is deliberately NOT kept: it governs which
# uid runs the proof and must come from the gov-owned env file, never the agent.

# PWFG_PLAN is kept gov->agent so the proof wrapper (run as agent) reads the proof
# from the locked plan; the value is gov's, the agent never sets it. The PWFG_UV_*
# vars (Path A offline-uv) are likewise gov-SET (the pwfg-loop unit) and must survive
# `sudo -u agent run-proof-as.sh`; the agent's own UV_* never survive (env reset) and
# the agent is not the sudo caller, so it can never redirect the cache.
Defaults:gov   env_keep += "PWFG_PROMPT PWFG_MAX_TURNS PWFG_MODEL PWFG_PROXY_PORT PWFG_PLAN PWFG_UV_OFFLINE PWFG_UV_CACHE_DIR PWFG_UV_PYTHON_DIR"
Defaults:agent env_keep += "PWFG_ENV_FILE"

# gov launches the agent's claude session, and runs each phase's proof as the agent
# uid via run-proof-as.sh (a FIXED gov-owned wrapper that reads the proof from the
# locked plan — so this grant is one script, never an arbitrary `bash` as agent).
gov   ALL=(agent) NOPASSWD: /srv/pwfg/bin/launch-agent.sh, /srv/pwfg/skill/bin/run-proof-as.sh

# The agent reaches the verifier ONLY through these gov-owned scripts.
agent ALL=(gov) NOPASSWD: /srv/pwfg/skill/bin/verify-task.sh, /srv/pwfg/skill/bin/verify-all.sh, /srv/pwfg/skill/bin/escalate.sh

# The agent's Stop hook runs as gov so it can read/write the gov-only state dir.
agent ALL=(gov) NOPASSWD: /srv/pwfg/skill/bin/stop-gate.sh

# Read-only watch crossing (Path A): the SSM operator reviews the run via watch.sh,
# whose attach path hardcodes `tmux attach -r`, so even through sudo the operator can
# neither inject input nor kill the loop — distinct from the boundary crossings above.
# NOTE (first-real-box): the SSM default user is ssm-user in most accounts; if your
# Session Manager Run-As is ec2-user, change the principal accordingly.
ssm-user ALL=(gov) NOPASSWD: /srv/pwfg/skill/bin/watch.sh
