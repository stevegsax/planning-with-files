# pwfg boundary sudo rules. Two crossings only:
#   gov -> agent : spawn the unprivileged worker (the launch seam)
#   agent -> gov : the NARROW verify bridge (safe because proof strings come only
#                  from the locked plan — TRAP 1 is closed in common.sh)
# Keep PWFG_* context across the boundary. The agent->gov direction carries ONLY
# PWFG_ENV_FILE (the path to the gov-owned env file); common.sh refuses to source
# it unless it is gov-owned and not group/other-writable, so the agent cannot point
# it at a file it wrote. PWFG_PROOF_AS is deliberately NOT kept: it governs which
# uid runs the proof and must come from the gov-owned env file, never the agent.

Defaults:gov   env_keep += "PWFG_PROMPT PWFG_MAX_TURNS PWFG_MODEL PWFG_PROXY_PORT"
Defaults:agent env_keep += "PWFG_ENV_FILE"

# gov launches the agent's claude session.
gov   ALL=(agent) NOPASSWD: /srv/pwfg/bin/launch-agent.sh

# The agent reaches the verifier ONLY through these gov-owned scripts.
agent ALL=(gov) NOPASSWD: /srv/pwfg/skill/bin/verify-task.sh, /srv/pwfg/skill/bin/verify-all.sh, /srv/pwfg/skill/bin/escalate.sh

# The agent's Stop hook runs as gov so it can read/write the gov-only state dir.
agent ALL=(gov) NOPASSWD: /srv/pwfg/skill/bin/stop-gate.sh
