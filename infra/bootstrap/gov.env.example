# gov.env — PWFG_* context for the gov-run tools, sourced by common.sh via
# PWFG_ENV_FILE. Copy to /srv/pwfg/gov/env (gov:pwfg 0640) and set the locked plan
# for the run. Paths only — NO secrets (the key lives in the proxy's keyring).

export PWFG_PLAN=/srv/pwfg/locked/plan.json
export PWFG_SCHEMA=/srv/pwfg/skill/schema/plan.schema.json
export PWFG_WORKSPACE=/srv/pwfg/workspace
export PWFG_STATE_DIR=/srv/pwfg/state
# The locked plan + seed workspace at these paths are populated at boot by
# pwfg-prime.service (select-example.sh) from PWFG_EXAMPLE (set in that unit; default
# 'toy'). PWFG_PLAN stays .../locked/plan.json for every example, so these paths are
# example-independent.

# The proxy port the agent's ANTHROPIC_BASE_URL points at (matches pwfg-proxy.service).
export PWFG_PROXY_PORT=8787
# The brokering proxy's hard-cost-ceiling sentinel (matches PWFG_PROXY_STATE in
# pwfg-proxy.service). REQUIRED: without it the orchestrator no-ops the budget check, so
# a spent cost cap's 403s look like crashes (rollback + retry + phantom escalation)
# instead of a clean budget-ceiling escalation. See run-loop.sh.
export PWFG_PROXY_SENTINEL=/srv/pwfg/proxy/PROXY_BUDGET_EXHAUSTED

# Off-box notification channel (optional). The orchestrator records every outcome
# locally and fires this on escalation; see skill/bin/notify.sh.
# export PWFG_NOTIFY_CMD='curl -s -d "$(cat)" ntfy.sh/your-topic'
