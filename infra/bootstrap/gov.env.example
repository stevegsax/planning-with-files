# gov.env — PWFG_* context for the gov-run tools, sourced by common.sh via
# PWFG_ENV_FILE. Copy to /srv/pwfg/gov/env (gov:pwfg 0640) and set the locked plan
# for the run. Paths only — NO secrets (the key lives in the proxy's keyring).

export PWFG_PLAN=/srv/pwfg/locked/plan.json
export PWFG_SCHEMA=/srv/pwfg/skill/schema/plan.schema.json
export PWFG_WORKSPACE=/srv/pwfg/workspace
export PWFG_STATE_DIR=/srv/pwfg/state

# Off-box notification channel (optional). The orchestrator records every outcome
# locally and fires this on escalation; see skill/bin/notify.sh.
# export PWFG_NOTIFY_CMD='curl -s -d "$(cat)" ntfy.sh/your-topic'
