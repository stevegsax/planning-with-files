{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://saxcapital.co/schemas/plan-with-files-gated/plan.schema.json",
  "title": "Gated plan",
  "description": "A locked, governance-owned plan. Each phase declares the proof command that objectively proves it is done; completion is derived from running those commands, never asserted by the agent.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "name", "phases"],
  "properties": {
    "schema_version": { "const": "1" },
    "name": { "type": "string", "minLength": 1 },
    "workdir": {
      "type": "string",
      "default": ".",
      "description": "Directory (relative to this file) from which proof commands run."
    },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "proof"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$",
            "description": "Stable, unique phase identifier."
          },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "proof": {
            "type": "string",
            "minLength": 1,
            "description": "Shell command proving this phase. Exit 0 == pass. Authored by governance; the agent cannot change what counts as done."
          }
        }
      }
    }
  }
}
